# ======================================================================
# Supabase Edge Functions 環境変数テンプレ
#   本番設定は `pnpm exec supabase secrets set --env-file <file>` で投入する。
#   ローカルの `supabase functions serve` もこのファイルを読み込む。
# ======================================================================

# --- Supabase (service_role は RLS を bypass する。絶対に公開しない) ---
SUPABASE_URL=https://hvvsdqigktcbtakzcmnm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic Claude API ---
# 推奨モデル: claude-sonnet-4-6（200-300字の自然文に最適）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- LIFF / LINE は Phase C (parent pull model) では未使用 ---
# 将来 cron + LINE push を追加するときに LINE_CHANNEL_ACCESS_TOKEN を投入する。
